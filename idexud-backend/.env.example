# =============================================================================
#  .env.example — Sistema de Pólizas Idexud / Universidad Distrital
#  ⚠️  Copia este archivo a ".env" y ajusta los valores.
#      NUNCA subas el .env real al repositorio Git.
# =============================================================================

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=idexud_user
POSTGRES_PASSWORD=CambiaEstoEnProduccion123!
POSTGRES_DB=idexud_polizas
POSTGRES_PORT=5432

# ─── pgAdmin ─────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@idexud.edu.co
PGADMIN_PASSWORD=pgadmin_secreto
PGADMIN_PORT=5050

# ─── FastAPI ─────────────────────────────────────────────────────────────────
# Construida automáticamente por config.py, pero puedes forzarla aquí:
# DATABASE_URL=postgresql+asyncpg://idexud_user:pass@localhost:5432/idexud_polizas

SECRET_KEY=genera-una-clave-segura-con-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ─── Seguridad — API Key (hardening pre-JWT) ─────────────────────────────────
# Protege los endpoints de escritura (POST/PATCH/DELETE) mientras se integra JWT.
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Debe coincidir con VITE_API_KEY del frontend.
API_KEY=reemplazar-con-secrets.token_urlsafe-32

# ─── Entorno ─────────────────────────────────────────────────────────────────
ENVIRONMENT=development    # development | staging | production
LOG_LEVEL=DEBUG            # DEBUG | INFO | WARNING | ERROR

# ─── Email (alertas de vencimiento) ──────────────────────────────────────────
MAIL_USERNAME=notificaciones@idexud.edu.co
MAIL_PASSWORD=clave_correo
MAIL_FROM=notificaciones@idexud.edu.co
MAIL_PORT=587
MAIL_SERVER=smtp.udistrital.edu.co
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# ─── Alertas (días de anticipación para notificar vencimiento) ────────────────
ALERT_DAYS_BEFORE_EXPIRY=30,15,7,3,1

# ─── Almacenamiento de documentos ────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
